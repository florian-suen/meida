<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="using:Meida.Desktop.ViewModels"
             x:Class="Meida.Desktop.Views.Scales.ScalesDiagramView"
             x:DataType="vm:ScalesDiagramViewModel">
    <StackPanel>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal"
                    Spacing="10">

            <TextBlock VerticalAlignment="Center" TextAlignment="Center" Text="{Binding PositionName}"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="{DynamicResource SukiText}" />

        </StackPanel>
        <Panel Margin="0,20,0,0" HorizontalAlignment="Center">

            <TextBlock
                Margin="7,-13,0,0"
                Text="{Binding BaseFretLabel}"
                FontSize="10" FontWeight="Bold"
                Foreground="White" />

            <Grid Margin="0,15,0,0" ClipToBounds="False">
                <Line StartPoint="0,0" EndPoint="150,0" Stroke="Gray"
                      StrokeThickness="2" />
                <Line StartPoint="0,26" EndPoint="150,26" Stroke="Gray"
                      StrokeThickness="2" />
                <Line StartPoint="0,52" EndPoint="150,52" Stroke="Gray"
                      StrokeThickness="2" />
                <Line StartPoint="0,78" EndPoint="150,78" Stroke="Gray"
                      StrokeThickness="2" />
                <Line StartPoint="0,104" EndPoint="150,104" Stroke="Gray"
                      StrokeThickness="2" />
                <Line StartPoint="0,130" EndPoint="150,130" Stroke="Gray"
                      StrokeThickness="2" />
                <Line StartPoint="0.5,1.5" EndPoint="0,129.4" Stroke="Black" StrokeThickness="2" />
                <Line StartPoint="30,1.5" EndPoint="30,129" Stroke="Black" StrokeThickness="2" />
                <Line StartPoint="60,1.5" EndPoint="60,129" Stroke="Black" StrokeThickness="2" />
                <Line StartPoint="90,1.5" EndPoint="90,129" Stroke="Black" StrokeThickness="2" />
                <Line StartPoint="120,1.5" EndPoint="120,129" Stroke="Black" StrokeThickness="2" />
                <Line StartPoint="149.5,1.5" EndPoint="150,129" Stroke="Black" StrokeThickness="2" />
                <ItemsControl ClipToBounds="False" ItemsSource="{Binding Fingers}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Panel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Width="16" Height="16"
                                  ClipToBounds="False"
                                  HorizontalAlignment="Left" VerticalAlignment="Top"
                                  Margin="{Binding PositionMargin}">
                                <Ellipse Fill="#4774B9" />
                                <TextBlock Text="{Binding Note}"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Panel>
        <ToggleButton Margin="0,20,0,0" Content="Play Scale" />
    </StackPanel>
</UserControl>