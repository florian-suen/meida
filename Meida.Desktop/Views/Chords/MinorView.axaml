<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:views="using:Meida.Desktop.Views.Chords"
             xmlns:vm="using:Meida.Desktop.ViewModels"
             xmlns:sukiUi="clr-namespace:SukiUI.Controls;assembly=SukiUI"
             x:DataType="vm:ChordsViewModel"
             x:Class="Meida.Desktop.Views.Chords.MinorView">
    <ItemsControl
        ItemsSource="{Binding MinChords }">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <WrapPanel ItemSpacing="20" LineSpacing="20" Margin="30"
                           HorizontalAlignment="Center" />
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <sukiUi:GlassCard IsInteractive="True" Margin="10">
                    <views:ChordsDiagramView ClipToBounds="False" />
                </sukiUi:GlassCard>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>